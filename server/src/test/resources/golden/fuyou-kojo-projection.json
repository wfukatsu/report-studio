                    { "type": "checkbox", "checked": false, "text": "源泉控除" }
                  ]
                },
                {
                  "height": 8,
                  "role": "body",
                  "cells": [
                    { "type": "label", "text": "配偶者" },
                    { "type": "dataField", "fieldKey": "spouse.name" },
                    { "type": "eraSelect", "eraDataSource": "spouse.era" },
                    { "type": "label", "text": "妻" },
                    { "type": "checkbox", "checked": true, "text": "源泉控除" }
                  ]
                }
              ],
              "_formData": {
                "taxpayer.name": "山田太郎",
                "taxpayer.era": "昭",
                "spouse.name": "山田花子",
                "spouse.era": "平"
              }
            },
            {
              "id": "seal",
              "kind": "seal_box",
              "name": "押印欄",
              "frame": { "x": 250, "y": 25, "width": 15, "height": 15, "rotation": 0 },
