                { "width": 35 },
                { "width": 60 },
                { "width": 60 },
                { "width": 45 },
                { "width": 50 }
              ],
              "rows": [
                {
                  "height": 8,
                  "role": "header",
                  "cells": [
                    { "type": "label", "text": "区分" },
                    { "type": "label", "text": "氏名（フリガナ）" },
                    { "type": "label", "text": "生年月日" },
                    { "type": "label", "text": "続柄" },
                    { "type": "label", "text": "控除区分" }
