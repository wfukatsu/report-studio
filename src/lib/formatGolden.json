{
  "description": "Shared golden fixture pinning front<->server formatter parity (#329 Phase 4). Consumed by src/lib/numberFormatter.parity.test.ts (frontend) AND server ValueFormatterParityTest.java. Each case calls applyFormat(value, format) on both sides and must produce `expected`. Date values use a local `T00:00:00` form (no timezone offset) so both runtimes resolve the same civil date regardless of the machine's timezone. Custom-with-date-pattern via applyFormat is intentionally excluded (a documented front/server routing divergence).",
  "cases": [
    { "name": "integer rounds half-up", "value": 1234.9, "format": { "type": "integer" }, "expected": "1235" },
    { "name": "decimal 2 places", "value": 1234.5678, "format": { "type": "decimal", "decimalPlaces": 2 }, "expected": "1234.57" },
    { "name": "currency_jpy small", "value": 1234, "format": { "type": "currency_jpy" }, "expected": "¥1,234" },
    { "name": "currency_jpy grouped", "value": 1234567, "format": { "type": "currency_jpy" }, "expected": "¥1,234,567" },
    { "name": "currency_usd two decimals", "value": 1234.5, "format": { "type": "currency_usd" }, "expected": "$1,234.50" },
    { "name": "percent 1 place", "value": 0.1234, "format": { "type": "percent", "decimalPlaces": 1 }, "expected": "12.3%" },
    { "name": "comma integer", "value": 1234567, "format": { "type": "comma" }, "expected": "1,234,567" },
    { "name": "comma fractional", "value": 1234.5, "format": { "type": "comma" }, "expected": "1,234.5" },
    { "name": "kanji zero", "value": 0, "format": { "type": "kanji_numeral" }, "expected": "金零円也" },
    { "name": "kanji thousand", "value": 1000, "format": { "type": "kanji_numeral" }, "expected": "金千円也" },
    { "name": "kanji man", "value": 10000, "format": { "type": "kanji_numeral" }, "expected": "金壱万円也" },
    { "name": "kanji million", "value": 1000000, "format": { "type": "kanji_numeral" }, "expected": "金百万円也" },
    { "name": "kanji complex", "value": 1234567, "format": { "type": "kanji_numeral" }, "expected": "金百弐拾参万四千伍百六拾七円也" },
    { "name": "custom grouped 2dp", "value": 1234.5, "format": { "type": "custom", "customPattern": "#,##0.00" }, "expected": "1,234.50" },
    { "name": "custom yen prefix", "value": 1234.9, "format": { "type": "custom", "customPattern": "¥#,##0" }, "expected": "¥1,235" },
    { "name": "custom one decimal", "value": 42, "format": { "type": "custom", "customPattern": "0.0" }, "expected": "42.0" },
    { "name": "custom no pattern falls back", "value": 42, "format": { "type": "custom" }, "expected": "42" },
    { "name": "unknown type falls back", "value": 99, "format": { "type": "unknown_type" }, "expected": "99" },
    { "name": "date slash", "value": "2026-04-01T00:00:00", "format": { "type": "yyyy/MM/dd" }, "expected": "2026/04/01" },
    { "name": "date kanji", "value": "2026-04-01T00:00:00", "format": { "type": "yyyy年MM月dd日" }, "expected": "2026年4月1日" },
    { "name": "date us", "value": "2026-04-01T00:00:00", "format": { "type": "MM/dd/yyyy" }, "expected": "04/01/2026" },
    { "name": "wareki full reiwa", "value": "2026-04-01T00:00:00", "format": { "type": "wareki_full" }, "expected": "令和8年4月1日" },
    { "name": "wareki short reiwa", "value": "2026-04-01T00:00:00", "format": { "type": "wareki_short" }, "expected": "R08.04.01" },
    { "name": "wareki full heisei", "value": "2019-04-30T00:00:00", "format": { "type": "wareki_full" }, "expected": "平成31年4月30日" },
    { "name": "wareki full gannen", "value": "2019-05-01T00:00:00", "format": { "type": "wareki_full" }, "expected": "令和元年5月1日" },
    { "name": "wareki full showa boundary", "value": "1989-01-07T00:00:00", "format": { "type": "wareki_full" }, "expected": "昭和64年1月7日" },
    { "name": "date-only slash (civil parse)", "value": "2026-04-01", "format": { "type": "yyyy/MM/dd" }, "expected": "2026/04/01" },
    { "name": "date-only wareki gannen boundary (civil parse)", "value": "2019-05-01", "format": { "type": "wareki_full" }, "expected": "令和元年5月1日" },
    { "name": "address single", "value": { "postalCode": "100-0001", "address1": "東京都千代田区丸の内", "address2": "1-1-1" }, "format": { "type": "address_single" }, "expected": "〒100-0001 東京都千代田区丸の内1-1-1" },
    { "name": "address multiline", "value": { "postalCode": "100-0001", "address1": "東京都千代田区丸の内", "address2": "1-1-1" }, "format": { "type": "address_multiline" }, "expected": "〒100-0001\n東京都千代田区丸の内\n1-1-1" }
  ]
}
