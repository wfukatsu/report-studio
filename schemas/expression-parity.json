{
  "$comment": "#423: Shared JEXL expression parity fixture. Single source asserted by BOTH src/lib/jexlParity.test.ts (vitest, @pawel-up/jexl engine) and server ExpressionParityTest.java (JUnit, Apache JEXL engine). Add a case here when template-facing expression behavior must match between the editor test-run and server-side evaluation. Numeric comparison tolerance: 1e-9. All previously known divergences (sum/avg/min/max signatures, ifExpr truthiness, formatNumber grouping/yen-sign, round decimal boundary) were resolved in #449 and promoted to cases; record any new divergence in knownDivergences until fixed.",
  "cases": [
    {
      "name": "arith-multiply",
      "expression": "price * qty",
      "context": { "price": 100, "qty": 3 },
      "expected": 300
    },
    {
      "name": "arith-tax-float",
      "expression": "price * qty * 1.1",
      "context": { "price": 100, "qty": 3 },
      "expected": 330.00000000000006
    },
    {
      "name": "arith-parens",
      "expression": "(subtotal - discount) * 2",
      "context": { "subtotal": 1500, "discount": 200 },
      "expected": 2600
    },
    {
      "name": "round-two-places",
      "expression": "round(3.14159, 2)",
      "context": {},
      "expected": 3.14
    },
    {
      "name": "round-half-up-integer",
      "expression": "round(2.5, 0)",
      "context": {},
      "expected": 3
    },
    {
      "name": "count-rows",
      "expression": "count(items)",
      "context": { "items": [{ "q": 1 }, { "q": 2 }, { "q": 3 }] },
      "expected": 3
    },
    {
      "name": "concat-strings",
      "expression": "concat(lastName, ' ', firstName)",
      "context": { "lastName": "Yamada", "firstName": "Taro" },
      "expected": "Yamada Taro"
    },
    {
      "name": "concat-null-is-empty",
