  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:backend": "cd server && ./gradlew run",
    "seed": "cd server && ./gradlew seed",
    "dev:full": "concurrently -n backend,frontend -c blue,green \"npm run dev:backend\" \"npm run dev\"",
    "build": "tsc -b && vite build",
    "build:backend": "cd server && ./gradlew shadowJar",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:backend": "cd server && ./gradlew test",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate:schema": "vite-node scripts/generate-json-schema.ts",
    "build:samples": "node scripts/sample-forms/build.mjs",
    "seed:samples": "node scripts/sample-forms/seed.mjs",
    "cli": "node scripts/cli/report-studio.mjs",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
